{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Streamlit App",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "app.py",
                " --server.port ${STREAMLIT_SERVER_PORT} --server.address ${STREAMLIT_SERVER_ADDRESS}"
            ],
            "console": "integratedTerminal",
            "env": {
                "STREAMLIT_SERVER_PORT": "8080",
                "STREAMLIT_SERVER_ADDRESS": "0.0.0.0"
            }
        }
    ]
}